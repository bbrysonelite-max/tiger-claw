# Tiger Claw Web Onboarding — Environment Variables
# Copy to .env.local for local development, or set in your deployment environment.

# Required: Tiger Claw API base URL
# Production: https://api.tigerclaw.io (or your Cloud Run / GKE ingress URL)
# Local dev:  http://localhost:4000
NEXT_PUBLIC_API_URL=https://api.tigerclaw.io

# Required: Stripe publishable key (starts with pk_live_ or pk_test_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
