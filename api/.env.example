# Tiger Claw API — Environment Variables
# Copy to .env for local development

# PostgreSQL (platform registry)
DATABASE_URL=postgresql://botcraft:chatwoot123@localhost:5432/tiger_bot

# Redis
REDIS_URL=redis://localhost:6379

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin protection
ADMIN_TOKEN=change-me-to-a-strong-secret

# Admin Telegram alerts (super-tenant channel)
ADMIN_TELEGRAM_BOT_TOKEN=<your-admin-bot-token>
ADMIN_TELEGRAM_CHAT_ID=<your-chat-id>

# Hive token (shared secret between API and all tenant containers)
TIGER_CLAW_HIVE_TOKEN=change-me-to-a-strong-secret

# Four-layer key system
# Layer 1: Platform onboarding key (used during onboarding interview only)
PLATFORM_ONBOARDING_KEY=sk-ant-...
# Layer 4: Platform emergency key (fallback of last resort)
PLATFORM_EMERGENCY_KEY=sk-ant-...

# Container image to use
TIGER_CLAW_IMAGE=tiger-claw-scout:latest

# Self-referencing URL (injected into containers)
TIGER_CLAW_API_URL=http://host.docker.internal:4000

# Encryption key for tenant secrets
ENCRYPTION_KEY=d12231134357ba94a7abfbf546ffef4142d46a1f0dcdf45f168ec225e6b17ee8

# Serper search API keys (injected into containers)
SERPER_KEY_1=
SERPER_KEY_2=
SERPER_KEY_3=

# Port
PORT=4000
