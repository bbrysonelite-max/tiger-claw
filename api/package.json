{
  "name": "tiger-claw-api",
  "version": "2.0.0",
  "description": "Tiger Claw TenantOrchestrator — port 4000",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "postbuild": "mkdir -p dist/config/flavors && cp src/config/flavors/*.json dist/config/flavors/",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "TIGER_CLAW_API_URL=http://localhost:4000 REDIS_URL=redis://localhost:6379 DATABASE_URL=postgres://localhost:5432/db vitest run",
    "test:watch": "TIGER_CLAW_API_URL=http://localhost:4000 REDIS_URL=redis://localhost:6379 DATABASE_URL=postgres://localhost:5432/db vitest"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@kubernetes/client-node": "^1.4.0",
    "bullmq": "^5.70.2",
    "cors": "^2.8.6",
    "dockerode": "^4.0.2",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "ioredis": "^5.10.0",
    "node-telegram-bot-api": "^0.66.0",
    "pg": "^8.11.3",
    "redis": "^5.11.0",
    "stripe": "^14.14.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dockerode": "^3.3.23",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
