{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true
    },
    "include": [
        "tools/**/*.ts",
        "config/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}